# ── Video Downloader — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in any overrides.
# All variables are optional — the app works with defaults out of the box.

# Path to the yt-dlp binary.
# Default: "yt-dlp" (assumes it's in PATH)
# Override if yt-dlp is installed to a non-standard location.
# YTDLP_PATH=yt-dlp

# Node environment (set automatically in production)
# NODE_ENV=production

# Nitro server host and port (Docker / custom deployments)
# NITRO_HOST=0.0.0.0
# NITRO_PORT=3000
